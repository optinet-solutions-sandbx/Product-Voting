# =====================================================================
# PROJECT VOTING — environment variables
# Copy this file to `.env` and fill in your keys.
# =====================================================================

# --- Image generation -------------------------------------------------
# Provide ONE or BOTH. The generator falls back automatically.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Default provider when not specified on the command line.
# Options: gemini | openai
IMAGE_PROVIDER=gemini

# Gemini model used for reference-image-based generation.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# OpenAI model used for image generation.
OPENAI_IMAGE_MODEL=gpt-image-1
